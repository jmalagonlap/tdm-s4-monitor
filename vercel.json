{
  "public": true,
  "env": [
    {
      "key": "ARTIMO_PASSWORD",
      "description": "Contraseña para autenticación local",
      "example": "Artimo2026!"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
